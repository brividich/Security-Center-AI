# Security Center AI - profilo TEST Windows con SQL Server
# Copiare in .env solo sul PC di test e sostituire i valori placeholder.

DEBUG=True
SECRET_KEY=change-me-for-test-only
ALLOWED_HOSTS=127.0.0.1,localhost,<LAN_IP>

DB_ENGINE=mssql
DB_NAME=SecurityCenterAI_TEST
DB_HOST=localhost\SQLEXPRESS
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_TRUSTED_CONNECTION=True
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=True

# Alternativa con autenticazione SQL:
# DB_TRUSTED_CONNECTION=False
# DB_USER=security_center_test
# DB_PASSWORD=change-me
