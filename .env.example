DJANGO_SETTINGS_MODULE=security_center_ai.settings
# REQUIRED: Generate a strong secret key for production
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SECURITY_CENTER_DEV_MODE=True

# Security settings (set to True in production with HTTPS)
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Microsoft Graph mailbox ingestion.
# Compile these only on the Django/server machine. Never put real values in frontend code, tests, docs, screenshots, or commits.
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=token-redacted
GRAPH_MAIL_FOLDER=Inbox
